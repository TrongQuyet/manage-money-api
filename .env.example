# App
NODE_ENV=development
PORT=3334

# Database (MySQL running on host port 3308)
DB_HOST=localhost
DB_PORT=3308
DB_NAME=manage_money
DB_USER=manage_money_user
DB_PASSWORD=change_me_db_password

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_random_hex_access
JWT_REFRESH_SECRET=replace_with_64_byte_random_hex_refresh

# Bootstrap — used to protect POST /api/auth/register
REGISTRATION_SECRET=replace_with_registration_secret
